# ============================================================
# MEAMA PRMTR — environment template. Copy to .env and fill in.
# NEVER commit the real .env. Service-role key is backend-only.
# ============================================================

# ---- Supabase (backend) ----
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # backend ONLY — never ship to frontend

# ---- Anthropic ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Meta Marketing API ----
META_APP_ID=
META_APP_SECRET=
META_SYSTEM_USER_TOKEN=
META_AD_ACCOUNT_ID=

# ---- Shopify ----
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

# ---- Backend runtime ----
CORS_ORIGINS=http://localhost:5173
ENVIRONMENT=development

# ---- Frontend (Vite — only VITE_* is exposed to the browser) ----
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE_URL=http://localhost:8000
